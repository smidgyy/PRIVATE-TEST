{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "node server.js",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=esm --outfile=server.js --external:vite --external:express --external:firebase-admin --external:cors",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "esbuild": "^0.27.4",
    "express": "^5.2.1",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.7.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.15",
    "typescript": "~5.8.2"
  }
}
